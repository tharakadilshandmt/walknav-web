# ============================================
# WalkNav — Environment Variables
# ============================================
# Copy to .env and fill in your values.
# Vars marked [REQUIRED] must be set for production.

# ---- Database ----
DB_PASSWORD=walknav_dev_pass                 # [REQUIRED] PostgreSQL password
DATABASE_URL=postgres://walknav_user:walknav_dev_pass@localhost:5432/walknav

# ---- Authentication ----
JWT_SECRET=walknav-dev-jwt-secret-change-in-production   # [REQUIRED]

# ---- Mapbox ----
MAPBOX_TOKEN=your_mapbox_token_here          # [REQUIRED]

# ---- Server ----
PORT=3001
NODE_ENV=development                         # development | production
WEATHER_API_URL=https://api.open-meteo.com

# ---- Security ----
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173        # Comma-separated
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- Production Only ----
# HTTP_PORT=80                               # Nginx listen port
